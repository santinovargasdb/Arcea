# ─────────────────────────────────────────────────────────────
#  Arcea Estudio — variables de entorno
#  Copiá este archivo como `.env.local` y completá los valores.
#  `.env.local` está en .gitignore: NUNCA se commitea.
# ─────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────
# Dashboard → Project Settings → API (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECRETO. Solo servidor. Salta RLS. Nunca usar prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ─── MercadoPago ─────────────────────────────────────────────
# https://www.mercadopago.com.ar/developers → Tus integraciones
# Empezá con credenciales de PRUEBA (sandbox).
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ─── App ─────────────────────────────────────────────────────
# URL pública del sitio. Se usa para back_urls y notification_url
# de MercadoPago. En producción = dominio de Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
